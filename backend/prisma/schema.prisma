generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL")
}

enum CapsuleStatus {
  DRAFT           // criada, ainda não paga
  PENDING_PAYMENT // checkout iniciado, aguardando confirmação do PIX
  ACTIVE          // pagamento confirmado, cápsula visível publicamente
  ARCHIVED
}

enum CheckoutSessionStatus {
  PENDING
  PAID
  CANCELED
  EXPIRED
}

model Capsule {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  status        CapsuleStatus @default(DRAFT)

  // token secreto que só o criador possui — usado pra autenticar
  // ações de edição (PATCH/DELETE) sem precisar de login
  editToken     String        @unique @default(uuid())

  recipientName String?
  occasion      String?
  songUrl       String?
  songFileUrl   String? // URL do mp3 enviado via upload (Cloudinary), alternativa ao songUrl
  letter        String

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  timelineItems    TimelineItem[]
  checkoutSession  CheckoutSession?

  @@index([slug])
  @@index([status])
  @@index([editToken])
}

model TimelineItem {
  id         String   @id @default(uuid())
  capsuleId  String
  imageUrl   String
  caption    String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  capsule    Capsule  @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([capsuleId])
  @@index([sortOrder])
}

model CheckoutSession {
  id              String                 @id @default(uuid())
  capsuleId       String                 @unique
  provider        String                 @default("abacatepay")
  status          CheckoutSessionStatus  @default(PENDING)

  // ID retornado pela AbacatePay ao criar a cobrança (ex: "pix_char_xxx")
  // usado para reconciliar o webhook com esta sessão
  providerChargeId String?               @unique

  // dados retornados pela AbacatePay pra renderizar o PIX no front
  pixQrCode        String?               // brCodeBase64 (imagem)
  pixCopyPaste      String?              // brCode (copia e cola)

  amount          Int                    @default(0) // em centavos
  currency        String                 @default("BRL")

  expiresAt       DateTime?
  paidAt          DateTime?

  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  capsule         Capsule                @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@index([providerChargeId])
  @@index([status])
}
